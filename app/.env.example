# ===========================================================================
# UniEvent — Environment Variables Template
# Copy this file to .env and fill in real values before deployment.
# ===========================================================================

# Flask
FLASK_SECRET_KEY=replace-with-a-strong-random-string

# Ticketmaster Discovery API
# Get your free key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=YOUR_TICKETMASTER_API_KEY_HERE

# AWS S3
S3_BUCKET_NAME=unievent-media-YOUR_ACCOUNT_ID
AWS_REGION=us-east-1

# Fetch interval in seconds (default: 1800 = 30 minutes)
FETCH_INTERVAL=1800
